# Optimora — environment variable reference.
# Nothing here is required to build; each integration fails loudly (never
# fakes success) when its key is missing, and falls back to mock/demo
# behavior where a mock path exists.

# --- Database (apps/web + packages/db + services/platform) ---
DATABASE_URL=                      # Runtime Postgres URL, e.g. Supabase pooled/session URL for the app
DIRECT_DATABASE_URL=               # Direct/non-pooled Postgres URL for Prisma migrations and privileged DB tasks

# --- Auth (services/platform + apps/web) ---
AUTH_SECRET=                       # JWT signing secret for sessions
PLATFORM_API_URL=                  # Base URL of the deployed platform (Fastify) service, e.g. https://optimora-platform.onrender.com
NEXT_PUBLIC_TENANT_ID=             # Default tenant id sent by the web app to the platform API
BASE_DOMAINS=                      # Comma-separated allowed cookie/session domains

# --- Real email sending (Resend — https://resend.com, free tier) ---
RESEND_API_KEY=                    # Resend API key. Without it, magic-link email and the workflow "send_email" action fall back to logging-only (StubEmailSender / mock).
EMAIL_FROM="Optimora <onboarding@resend.dev>"   # Verified sender address/domain in Resend

# --- AI providers (packages/ai) ---
# AGENT_PROVIDER selects which provider runAgent() uses: mock | openrouter | openai | anthropic.
# If unset: defaults to "openrouter" when OPENROUTER_API_KEY is set, else "mock".
AGENT_PROVIDER=
OPENROUTER_API_KEY=                # https://openrouter.ai — primary real provider for now (one key, many models)
OPENROUTER_MODEL=openai/gpt-4o-mini
OPENAI_API_KEY=                    # https://platform.openai.com — kept ready as a placeholder/alternate provider
OPENAI_MODEL=gpt-4o-mini
ANTHROPIC_API_KEY=                 # https://console.anthropic.com — kept ready as a placeholder/alternate provider
ANTHROPIC_MODEL=claude-3-5-sonnet-20241022

# --- Google OAuth (shared client for sign-in + Gmail integration) ---
# Create an OAuth 2.0 Client ID in Google Cloud Console (APIs & Services →
# Credentials). Add BOTH redirect URIs below as authorized redirect URIs, and
# add the openid/email/profile (sign-in) and gmail.send (Gmail) scopes.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URI=          # sign-in: https://<your-domain>/api/auth/oauth/google/callback
GOOGLE_REDIRECT_URI=               # Gmail:   https://<your-domain>/api/integrations/gmail/callback

# Shared secret authenticating the web app's OAuth exchange call to the platform
# service. Must be identical on both the web app (Vercel) and platform (Render).
INTERNAL_AUTH_SECRET=

# Base URL of the deployed web app — the platform uses it to build magic-link
# sign-in URLs that point at /login (not at the platform host).
WEB_APP_URL=                       # e.g. https://optimora-web.vercel.app

# --- Google Calendar integration (interview scheduling — apps/web) ---
# Reuses the same OAuth client as sign-in/Gmail (GOOGLE_CLIENT_ID/SECRET).
# In Google Cloud Console add the calendar.events scope to that OAuth client
# and register the redirect URI below as an authorized redirect URI.
GOOGLE_CALENDAR_REDIRECT_URI=       # Calendar: https://<your-domain>/api/integrations/google-calendar/callback

# --- Resume file storage (Vercel Blob — apps/web) ---
# Auto-provisioned by Vercel once you create a Blob store: Vercel dashboard →
# Storage → Create Database → Blob. Without it, the resume upload route returns
# a clear requires_setup error (never a faked success).
BLOB_READ_WRITE_TOKEN=              # Vercel Blob read/write token (apps/web project)

# --- Google Sheets integration (architecture-only placeholder, not implemented yet) ---
GOOGLE_SHEETS_OAUTH_ENABLED=false

# --- Demo/dev mode toggles ---
DEMO_MODE=false
NEXT_PUBLIC_DEMO_MODE=false
STAGING_DEMO_LOGIN=false

# --- Webhook signing ---
WEBHOOK_SIGNING_SECRET=
WEBHOOK_ALLOW_UNSIGNED=false       # Only for local/staging demo webhook testing when WEBHOOK_SIGNING_SECRET is intentionally absent

# --- Public client-side config (apps/web) ---
NEXT_PUBLIC_API_BASE_URL=
NEXT_PUBLIC_API_KEY=                # SDK key prefixed "opt_" — enables real Public API calls instead of mock data in src/lib/data.ts
NEXT_PUBLIC_ORG_ID=
NEXT_PUBLIC_AGENCY_NAME=
NEXT_PUBLIC_WORKSPACE_NAME=
NEXT_PUBLIC_WORKSPACE_SLUG=
NEXT_PUBLIC_PLAN_KEY=

# --- Temporal (workflow durability, services/platform) ---
TEMPORAL_ADDRESS=
TEMPORAL_NAMESPACE=
TEMPORAL_TASK_QUEUE_BASE=
TEMPORAL_LOG_LEVEL=

# --- Misc ---
PORT=
NODE_ENV=

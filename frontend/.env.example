# Optimora — environment variable reference.
# Nothing here is required to build; each integration fails loudly (never
# fakes success) when its key is missing, and falls back to mock/demo
# behavior where a mock path exists.

# --- Database (apps/web + packages/db + services/platform) ---
DATABASE_URL=                      # Postgres connection string (required for any real data)

# --- Auth (services/platform + apps/web) ---
AUTH_SECRET=                       # JWT signing secret for sessions
PLATFORM_API_URL=                  # Base URL of the deployed platform (Fastify) service, e.g. https://optimora-platform.onrender.com
NEXT_PUBLIC_TENANT_ID=             # Default tenant id sent by the web app to the platform API
BASE_DOMAINS=                      # Comma-separated allowed cookie/session domains

# --- Real email sending (Resend — https://resend.com, free tier) ---
RESEND_API_KEY=                    # Resend API key. Without it, magic-link email and the workflow "send_email" action fall back to logging-only (StubEmailSender / mock).
EMAIL_FROM="Optimora <onboarding@resend.dev>"   # Verified sender address/domain in Resend

# --- AI providers (packages/ai) ---
# AGENT_PROVIDER selects which provider runAgent() uses: mock | openrouter | openai | anthropic.
# If unset: defaults to "openrouter" when OPENROUTER_API_KEY is set, else "mock".
AGENT_PROVIDER=
OPENROUTER_API_KEY=                # https://openrouter.ai — primary real provider for now (one key, many models)
OPENROUTER_MODEL=openai/gpt-4o-mini
OPENAI_API_KEY=                    # https://platform.openai.com — kept ready as a placeholder/alternate provider
OPENAI_MODEL=gpt-4o-mini
ANTHROPIC_API_KEY=                 # https://console.anthropic.com — kept ready as a placeholder/alternate provider
ANTHROPIC_MODEL=claude-3-5-sonnet-20241022

# --- Gmail integration (real OAuth — apps/web/src/lib/integrations/gmail.ts) ---
# Create an OAuth 2.0 Client ID in Google Cloud Console (APIs & Services →
# Credentials), enable the Gmail API, add the gmail.send scope, and add
# GOOGLE_REDIRECT_URI as an authorized redirect URI.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=                # e.g. https://<your-domain>/api/integrations/gmail/callback

# --- Google Sheets integration (architecture-only placeholder, not implemented yet) ---
GOOGLE_SHEETS_OAUTH_ENABLED=false

# --- Demo/dev mode toggles ---
DEMO_MODE=false
NEXT_PUBLIC_DEMO_MODE=false
STAGING_DEMO_LOGIN=false

# --- Webhook signing ---
WEBHOOK_SIGNING_SECRET=

# --- Public client-side config (apps/web) ---
NEXT_PUBLIC_API_BASE_URL=
NEXT_PUBLIC_API_KEY=                # SDK key prefixed "opt_" — enables real Public API calls instead of mock data in src/lib/data.ts
NEXT_PUBLIC_ORG_ID=
NEXT_PUBLIC_AGENCY_NAME=
NEXT_PUBLIC_WORKSPACE_NAME=
NEXT_PUBLIC_WORKSPACE_SLUG=
NEXT_PUBLIC_PLAN_KEY=

# --- Temporal (workflow durability, services/platform) ---
TEMPORAL_ADDRESS=
TEMPORAL_NAMESPACE=
TEMPORAL_TASK_QUEUE_BASE=
TEMPORAL_LOG_LEVEL=

# --- Misc ---
PORT=
NODE_ENV=

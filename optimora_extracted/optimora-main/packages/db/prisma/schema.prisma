  createdAt          DateTime  @default(now()) @map("created_at")
  updatedAt          DateTime  @updatedAt @map("updated_at")

  @@index([tenantId])
  @@index([orgId])
  @@index([status])
  @@map("billing_subscriptions")
}

/// Billing outbox event. Tenant-scoped (RLS).
model BillingEvent {
  id        String   @id @default(uuid()) @db.Uuid
  tenantId  String   @map("tenant_id") @db.Uuid
  subId     String?  @map("sub_id") @db.Uuid
  type      String
  payload   Json     @default("{}")
  createdAt DateTime @default(now()) @map("created_at")

  @@index([tenantId])
  @@index([subId])
  @@map("billing_events")
}

/// Automation OS workspace. This complements the platform Organization model
/// with the workspace_id surface expected by pack deployment, ROI, activity,
/// approvals, and agency client operations.
model Workspace {
  id          String   @id @default(uuid()) @db.Uuid
  tenantId    String   @map("tenant_id") @db.Uuid
  orgId       String?  @map("org_id") @db.Uuid
  name        String
  slug        String
  type        String   @default("business")
  status      String   @default("active")
  industryKey String?  @map("industry_key")
  brandMeta   Json     @default("{}") @map("brand_meta")
  settings    Json     @default("{}")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  members                WorkspaceMember[]
  agencyClientWorkspaces AgencyClientWorkspace[]   @relation("AgencyWorkspace")
  clientAgencyWorkspaces AgencyClientWorkspace[]   @relation("ClientWorkspace")
  packDeployments        WorkspacePackDeployment[]
  deployedWorkflows      DeployedWorkflow[]
  agents                 Agent[]
  workspaceIntegrations  WorkspaceIntegration[]
  dataSources            DataSource[]
  uploadedFiles          UploadedFile[]
  businessObjects        BusinessObject[]
  activityLogs           ActivityLog[]
  roiMetrics             RoiMetric[]
  workflowRoiSnapshots   WorkflowRoiSnapshot[]
  approvals              Approval[]
  agentRuns              AgentRun[]
  automationEvents       AutomationEvent[]

  @@unique([tenantId, slug])
  @@index([tenantId])
  @@index([orgId])
  @@index([industryKey])
  @@map("workspaces")
}

/// Workspace-level membership with role metadata. User is optional so invited
/// members can exist before signup.
model WorkspaceMember {
  id          String   @id @default(uuid()) @db.Uuid
  tenantId    String   @map("tenant_id") @db.Uuid
  workspaceId String   @map("workspace_id") @db.Uuid
  userId      String?  @map("user_id") @db.Uuid
  email       String?
  role        String   @default("member")
  status      String   @default("active")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  user      User?     @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@unique([workspaceId, userId])
  @@index([tenantId])
  @@index([workspaceId])
  @@index([userId])
  @@map("workspace_members")
}

/// Agency-managed client workspace link. Used for white-label pack deployment,
/// client-level ROI, approvals, and activity feeds.
model AgencyClientWorkspace {
  id                String   @id @default(uuid()) @db.Uuid
  tenantId          String   @map("tenant_id") @db.Uuid
  agencyWorkspaceId String   @map("agency_workspace_id") @db.Uuid
  clientWorkspaceId String   @map("client_workspace_id") @db.Uuid
  clientName        String   @map("client_name")
  industryKey       String?  @map("industry_key")
  status            String   @default("active")
  brandingMeta      Json     @default("{}") @map("branding_meta")
  approvalPolicy    Json     @default("{}") @map("approval_policy")
  roiReportConfig   Json     @default("{}") @map("roi_report_config")
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")

  agencyWorkspace Workspace @relation("AgencyWorkspace", fields: [agencyWorkspaceId], references: [id], onDelete: Cascade)
  clientWorkspace Workspace @relation("ClientWorkspace", fields: [clientWorkspaceId], references: [id], onDelete: Cascade)

  @@unique([agencyWorkspaceId, clientWorkspaceId])
  @@index([tenantId])
  @@index([agencyWorkspaceId])
  @@index([clientWorkspaceId])
  @@map("agency_client_workspaces")
}

// ═══════════════════════════════════════════════════════════════════════════════
// AUTOMATION OS — Industry Packs, Agents, Workflow Engine, ROI, Activity
// ═══════════════════════════════════════════════════════════════════════════════

/// Global catalog of industry packs. Not tenant-scoped.
model IndustryPack {
  id                   String   @id @default(uuid()) @db.Uuid
  key                  String   @unique
  name                 String
  icon                 String
  color                String
  headline             String
  description          String
  hoursSaved           Int      @default(0) @map("hours_saved")
  status               String   @default("demo")
  targetBuyer          String   @default("") @map("target_buyer")
  businessOutcome      String   @default("") @map("business_outcome")
  roiEstimate          String   @default("") @map("roi_estimate")
  sampleOutput         String   @default("") @map("sample_output")
  dashboardKpis        Json     @default("[]") @map("dashboard_kpis")
  requiredIntegrations Json     @default("[]") @map("required_integrations")
  approvalRequirements Json     @default("[]") @map("approval_requirements")
  setupStatus          String   @default("demo") @map("setup_status")
  createdAt            DateTime @default(now()) @map("created_at")
  updatedAt            DateTime @updatedAt @map("updated_at")

  workflows         IndustryPackWorkflow[]
  agents            IndustryPackAgent[]
  packDeployments   WorkspacePackDeployment[]
  deployedWorkflows DeployedWorkflow[]

  @@map("industry_packs")
}

/// M2M: industry pack -> workflow template.
model IndustryPackWorkflow {
  packId       String @map("pack_id") @db.Uuid
  workflowKey  String @map("workflow_key")
  workflowName String @default("") @map("workflow_name")
  baseType     String @default("") @map("base_type")
  config       Json   @default("{}")
  sortOrder    Int    @default(0) @map("sort_order")

  pack IndustryPack @relation(fields: [packId], references: [id], onDelete: Cascade)

  @@id([packId, workflowKey])
  @@map("industry_pack_workflows")
}

/// M2M: industry pack -> agent definition.
model IndustryPackAgent {
  packId    String @map("pack_id") @db.Uuid
  agentKey  String @map("agent_key")
  agentName String @default("") @map("agent_name")
  role      String @default("")
  sortOrder Int    @default(0) @map("sort_order")

  pack IndustryPack @relation(fields: [packId], references: [id], onDelete: Cascade)

  @@id([packId, agentKey])
  @@map("industry_pack_agents")
}

/// Global catalog of reusable agent definitions.
model AgentDefinition {
  id                   String   @id @default(uuid()) @db.Uuid
  key                  String   @unique
  name                 String
  icon                 String
  color                String
  tagline              String
  description          String
  inputs               Json     @default("[]")
  outputs              Json     @default("[]")
  approvalRequired     Boolean  @default(false) @map("approval_required")
  integrationRequired  Boolean  @default(false) @map("integration_required")
  integrations         Json     @default("[]")
  compatibleWorkflows  Json     @default("[]") @map("compatible_workflows")
  industries           Json     @default("[]")
  actionsPerformed     Json     @default("[]") @map("actions_performed")
  approvalRequirements Json     @default("[]") @map("approval_requirements")
  status               String   @default("demo")
  createdAt            DateTime @default(now()) @map("created_at")
  updatedAt            DateTime @updatedAt @map("updated_at")

  agents         Agent[]
  templateAgents WorkflowTemplateAgent[]

  @@map("agent_definitions")
}

/// Workspace-owned agent instance derived from the global agent library.
model Agent {
  id           String   @id @default(uuid()) @db.Uuid
  tenantId     String   @map("tenant_id") @db.Uuid
  workspaceId  String   @map("workspace_id") @db.Uuid
  definitionId String?  @map("definition_id") @db.Uuid
  key          String
  name         String
  role         String   @default("")
  status       String   @default("demo")
  config       Json     @default("{}")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  workspace              Workspace               @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  definition             AgentDefinition?        @relation(fields: [definitionId], references: [id], onDelete: SetNull)
  deployedWorkflowAgents DeployedWorkflowAgent[]

  @@unique([workspaceId, key])
  @@index([tenantId])
  @@index([workspaceId])
  @@index([definitionId])
  @@map("agents")
}

/// Global catalog of workflow templates.
model WorkflowTemplate {
  id                   String   @id @default(uuid()) @db.Uuid
  key                  String   @unique
  name                 String
  icon                 String
  color                String
  baseType             String   @default("") @map("base_type")
  industryKey          String?  @map("industry_key")
  trigger              String
  businessUseCase      String   @default("") @map("business_use_case")
  requiredInputs       Json     @default("[]") @map("required_inputs")
  requiredIntegrations Json     @default("[]") @map("required_integrations")
  approvalCheckpoints  Json     @default("[]") @map("approval_checkpoints")
  roiMetricsTracked    Json     @default("[]") @map("roi_metrics_tracked")
  sampleOutput         String   @default("") @map("sample_output")
  roiEstimate          String   @default("") @map("roi_estimate")
  setupStatus          String   @default("demo") @map("setup_status")
  status               String   @default("demo")
  createdAt            DateTime @default(now()) @map("created_at")
  updatedAt            DateTime @updatedAt @map("updated_at")

  steps             WorkflowTemplateStep[]
  agents            WorkflowTemplateAgent[]
  integrations      WorkflowTemplateIntegration[]
  deployedWorkflows DeployedWorkflow[]

  @@index([industryKey])
  @@index([baseType])
  @@map("workflow_templates")
}

/// Steps within a workflow template.
model WorkflowTemplateStep {
  id              String  @id @default(uuid()) @db.Uuid
  workflowId      String  @map("workflow_id") @db.Uuid
  stepNumber      Int     @map("step_number")
  label           String
  agentKey        String  @map("agent_key")
  humanCheckpoint Boolean @default(false) @map("human_checkpoint")
  inputSchema     Json    @default("{}") @map("input_schema")
  outputSchema    Json    @default("{}") @map("output_schema")

  workflow WorkflowTemplate @relation(fields: [workflowId], references: [id], onDelete: Cascade)

  @@index([workflowId])
  @@map("workflow_template_steps")
}

/// M2M: workflow template -> agent definition.
model WorkflowTemplateAgent {
  workflowId String @map("workflow_id") @db.Uuid
  agentKey   String @map("agent_key")
  role       String @default("")
  sortOrder  Int    @default(0) @map("sort_order")

  workflow        WorkflowTemplate @relation(fields: [workflowId], references: [id], onDelete: Cascade)
  agentDefinition AgentDefinition  @relation(fields: [agentKey], references: [key], onDelete: Cascade)

  @@id([workflowId, agentKey])
  @@index([agentKey])
  @@map("workflow_template_agents")
}

/// M2M: workflow template -> required integration key.
model WorkflowTemplateIntegration {
  workflowId     String  @map("workflow_id") @db.Uuid
  integrationKey String  @map("integration_key")
  required       Boolean @default(true)
  purpose        String  @default("")
  sortOrder      Int     @default(0) @map("sort_order")

  workflow WorkflowTemplate @relation(fields: [workflowId], references: [id], onDelete: Cascade)

  @@id([workflowId, integrationKey])
  @@index([integrationKey])
  @@map("workflow_template_integrations")
}

/// Workspace-level record that a full industry pack was deployed.
model WorkspacePackDeployment {
  id          String   @id @default(uuid()) @db.Uuid
  tenantId    String   @map("tenant_id") @db.Uuid
  orgId       String   @map("org_id") @db.Uuid
  workspaceId String   @map("workspace_id") @db.Uuid
  packId      String   @map("pack_id") @db.Uuid
  status      String   @default("demo")
  deployedBy  String?  @map("deployed_by") @db.Uuid
  settings    Json     @default("{}")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  workspace         Workspace          @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  pack              IndustryPack       @relation(fields: [packId], references: [id])
  deployedWorkflows DeployedWorkflow[]

  @@unique([workspaceId, packId])
  @@index([tenantId])
  @@index([orgId])
  @@index([workspaceId])
  @@index([packId])
  @@map("workspace_pack_deployments")
}

/// A workflow template deployed into an org workspace. Tenant+org scoped (RLS).
model DeployedWorkflow {
  id                String   @id @default(uuid()) @db.Uuid
  tenantId          String   @map("tenant_id") @db.Uuid
  orgId             String   @map("org_id") @db.Uuid
  workspaceId       String?  @map("workspace_id") @db.Uuid
  packDeploymentId  String?  @map("pack_deployment_id") @db.Uuid
  templateId        String   @map("template_id") @db.Uuid
  packId            String?  @map("pack_id") @db.Uuid
  name              String
  status            String   @default("demo")
  mode              String   @default("demo")
  deployedAt        DateTime @default(now()) @map("deployed_at")
  updatedAt         DateTime @updatedAt @map("updated_at")
  settings          Json     @default("{}")
  clientWorkspaceId String?  @map("client_workspace_id") @db.Uuid

  workspace               Workspace?                         @relation(fields: [workspaceId], references: [id], onDelete: SetNull)
  packDeployment          WorkspacePackDeployment?           @relation(fields: [packDeploymentId], references: [id], onDelete: SetNull)
  template                WorkflowTemplate                   @relation(fields: [templateId], references: [id])
  pack                    IndustryPack?                      @relation(fields: [packId], references: [id])
  steps                   DeployedWorkflowStep[]
  agents                  DeployedWorkflowAgent[]
  workflowSetting         WorkflowSetting?
  integrationRequirements DeploymentIntegrationRequirement[]
  runs                    WorkflowRun[]
  roiSnapshots            WorkflowRoiSnapshot[]
  approvals               Approval[]

  @@index([tenantId])
  @@index([orgId])
  @@index([workspaceId])
  @@index([packDeploymentId])
  @@index([templateId])
  @@map("deployed_workflows")
}

/// A copied step inside a deployed workflow. This preserves the template at
/// deployment time even if the global template changes later.
model DeployedWorkflowStep {
  id                 String   @id @default(uuid()) @db.Uuid
  tenantId           String   @map("tenant_id") @db.Uuid
  orgId              String   @map("org_id") @db.Uuid
  workspaceId        String?  @map("workspace_id") @db.Uuid
  deployedWorkflowId String   @map("deployed_workflow_id") @db.Uuid
  stepNumber         Int      @map("step_number")
  name               String
  agentKey           String   @map("agent_key")
  approvalRequired   Boolean  @default(false) @map("approval_required")
  status             String   @default("pending")
  inputSchema        Json     @default("{}") @map("input_schema")
  outputSchema       Json     @default("{}") @map("output_schema")
  createdAt          DateTime @default(now()) @map("created_at")
  updatedAt          DateTime @updatedAt @map("updated_at")

  deployedWorkflow DeployedWorkflow @relation(fields: [deployedWorkflowId], references: [id], onDelete: Cascade)

  @@unique([deployedWorkflowId, stepNumber])
  @@index([tenantId])
  @@index([orgId])
  @@index([workspaceId])
  @@index([deployedWorkflowId])
  @@map("deployed_workflow_steps")
}

/// Mapped agent instance for a deployed workflow.
model DeployedWorkflowAgent {
  id                 String   @id @default(uuid()) @db.Uuid
  tenantId           String   @map("tenant_id") @db.Uuid
  orgId              String   @map("org_id") @db.Uuid
  workspaceId        String?  @map("workspace_id") @db.Uuid
  deployedWorkflowId String   @map("deployed_workflow_id") @db.Uuid
  agentId            String?  @map("agent_id") @db.Uuid
  agentKey           String   @map("agent_key")
  role               String   @default("")
  status             String   @default("demo")
  config             Json     @default("{}")
  createdAt          DateTime @default(now()) @map("created_at")

  deployedWorkflow DeployedWorkflow @relation(fields: [deployedWorkflowId], references: [id], onDelete: Cascade)
  agent            Agent?           @relation(fields: [agentId], references: [id], onDelete: SetNull)

  @@unique([deployedWorkflowId, agentKey])
  @@index([tenantId])
  @@index([orgId])
  @@index([workspaceId])
  @@index([agentId])
  @@map("deployed_workflow_agents")
}

/// Runtime settings for a deployed workflow.
model WorkflowSetting {
  id                 String   @id @default(uuid()) @db.Uuid
  tenantId           String   @map("tenant_id") @db.Uuid
  orgId              String   @map("org_id") @db.Uuid
  workspaceId        String?  @map("workspace_id") @db.Uuid
  deployedWorkflowId String   @unique @map("deployed_workflow_id") @db.Uuid
  mode               String   @default("demo")
  approvalPolicy     Json     @default("{}") @map("approval_policy")
  integrationPolicy  Json     @default("{}") @map("integration_policy")
  roiBaseline        Json     @default("{}") @map("roi_baseline")
  createdAt          DateTime @default(now()) @map("created_at")
  updatedAt          DateTime @updatedAt @map("updated_at")

  deployedWorkflow DeployedWorkflow @relation(fields: [deployedWorkflowId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([orgId])
  @@index([workspaceId])
  @@map("workflow_settings")
}

/// Checklist row for an integration needed by a deployed workflow.
model DeploymentIntegrationRequirement {
  id                 String   @id @default(uuid()) @db.Uuid
  tenantId           String   @map("tenant_id") @db.Uuid
  orgId              String   @map("org_id") @db.Uuid
  workspaceId        String?  @map("workspace_id") @db.Uuid
  deployedWorkflowId String   @map("deployed_workflow_id") @db.Uuid
  integrationKey     String   @map("integration_key")
  status             String   @default("not_connected")
  required           Boolean  @default(true)
  notes              String   @default("")
  createdAt          DateTime @default(now()) @map("created_at")
  updatedAt          DateTime @updatedAt @map("updated_at")

  deployedWorkflow DeployedWorkflow @relation(fields: [deployedWorkflowId], references: [id], onDelete: Cascade)

  @@unique([deployedWorkflowId, integrationKey])
  @@index([tenantId])
  @@index([orgId])
  @@index([workspaceId])
  @@index([integrationKey])
  @@map("deployment_integration_requirements")
}

/// A single execution of a deployed workflow. Tenant+org scoped (RLS).
model WorkflowRun {
  id                 String    @id @default(uuid()) @db.Uuid
  tenantId           String    @map("tenant_id") @db.Uuid
  orgId              String    @map("org_id") @db.Uuid
  workspaceId        String?   @map("workspace_id") @db.Uuid
  deployedWorkflowId String    @map("deployed_workflow_id") @db.Uuid
  status             String    @default("queued")
  currentStep        Int       @default(0) @map("current_step")
  inputData          Json      @default("{}") @map("input_data")
  outputSummary      String?   @map("output_summary")
  errorMessage       String?   @map("error_message")
  startedAt          DateTime? @map("started_at")
  completedAt        DateTime? @map("completed_at")
  createdAt          DateTime  @default(now()) @map("created_at")
  updatedAt          DateTime  @updatedAt @map("updated_at")

  deployedWorkflow DeployedWorkflow  @relation(fields: [deployedWorkflowId], references: [id], onDelete: Cascade)
  steps            WorkflowRunStep[]
  agentRuns        AgentRun[]
  approvals        Approval[]

  @@index([tenantId])
  @@index([orgId])
  @@index([workspaceId])
  @@index([deployedWorkflowId])
  @@index([status])
  @@map("workflow_runs")
}

/// A step within a workflow run. Tenant-scoped (RLS).
model WorkflowRunStep {
  id               String    @id @default(uuid()) @db.Uuid
  tenantId         String    @map("tenant_id") @db.Uuid
  orgId            String?   @map("org_id") @db.Uuid
  workspaceId      String?   @map("workspace_id") @db.Uuid
  runId            String    @map("run_id") @db.Uuid
  stepNumber       Int       @map("step_number")
  label            String
  agentKey         String    @map("agent_key")
  status           String    @default("pending")
  approvalRequired Boolean   @default(false) @map("approval_required")
  inputData        Json      @default("{}") @map("input_data")
  outputData       Json      @default("{}") @map("output_data")
  logs             String?
  errorMessage     String?   @map("error_message")
  startedAt        DateTime? @map("started_at")
  completedAt      DateTime? @map("completed_at")

  run       WorkflowRun @relation(fields: [runId], references: [id], onDelete: Cascade)
  agentRuns AgentRun[]

  @@index([tenantId])
  @@index([orgId])
  @@index([workspaceId])
  @@index([runId])
  @@map("workflow_run_steps")
}

/// Workflow-specific approval request. Tenant+org scoped (RLS).
model WorkflowApproval {
  id              String    @id @default(uuid()) @db.Uuid
  tenantId        String    @map("tenant_id") @db.Uuid
  orgId           String    @map("org_id") @db.Uuid
  workspaceId     String?   @map("workspace_id") @db.Uuid
  runId           String    @map("run_id") @db.Uuid
  stepNumber      Int       @map("step_number")
  agentKey        String    @map("agent_key")
  actionType      String    @default("risky_action") @map("action_type")
  description     String
  proposedAction  Json      @default("{}") @map("proposed_action")
  status          String    @default("pending")
  reviewedBy      String?   @map("reviewed_by") @db.Uuid
  reviewedAt      DateTime? @map("reviewed_at")
  reviewerComment String?   @map("reviewer_comment")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  @@index([tenantId])
  @@index([orgId])
  @@index([workspaceId])
  @@index([runId])
  @@index([status])
  @@map("workflow_approvals")
}

/// General approval table for workflow, pack, and external-action approvals.
/// External sends remain blocked until both required integration and approval
/// rules are satisfied.
model Approval {
  id                 String    @id @default(uuid()) @db.Uuid
  tenantId           String    @map("tenant_id") @db.Uuid
  orgId              String    @map("org_id") @db.Uuid
  workspaceId        String    @map("workspace_id") @db.Uuid
  deployedWorkflowId String?   @map("deployed_workflow_id") @db.Uuid
  workflowRunId      String?   @map("workflow_run_id") @db.Uuid
  actionType         String    @map("action_type")
  title              String
  description        String
  proposedAction     Json      @default("{}") @map("proposed_action")
  status             String    @default("pending")
  requestedBy        String?   @map("requested_by") @db.Uuid
  approvedBy         String?   @map("approved_by") @db.Uuid
  approvedAt         DateTime? @map("approved_at")
  rejectedBy         String?   @map("rejected_by") @db.Uuid
  rejectedAt         DateTime? @map("rejected_at")
  changesRequestedBy String?   @map("changes_requested_by") @db.Uuid
  changesRequestedAt DateTime? @map("changes_requested_at")
  createdAt          DateTime  @default(now()) @map("created_at")
  updatedAt          DateTime  @updatedAt @map("updated_at")

  workspace        Workspace         @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  deployedWorkflow DeployedWorkflow? @relation(fields: [deployedWorkflowId], references: [id], onDelete: SetNull)
  workflowRun      WorkflowRun?      @relation(fields: [workflowRunId], references: [id], onDelete: SetNull)
  comments         ApprovalComment[]

  @@index([tenantId])
  @@index([orgId])
  @@index([workspaceId])
  @@index([deployedWorkflowId])
  @@index([workflowRunId])
  @@index([status])
  @@index([actionType])
  @@map("approvals")
}

model ApprovalComment {
  id         String   @id @default(uuid()) @db.Uuid
  approvalId String   @map("approval_id") @db.Uuid
  authorId   String?  @map("author_id") @db.Uuid
  comment    String
  createdAt  DateTime @default(now()) @map("created_at")

  approval Approval @relation(fields: [approvalId], references: [id], onDelete: Cascade)

  @@index([approvalId])
  @@map("approval_comments")
}

/// An available integration type in the catalog.
model IntegrationDefinition {
  id          String   @id @default(uuid()) @db.Uuid
  key         String   @unique
  name        String
  category    String
  icon        String?
  description String
  authMethod  String   @default("oauth") @map("auth_method")
  docsUrl     String?  @map("docs_url")
  status      String   @default("available")
  createdAt   DateTime @default(now()) @map("created_at")

  workspaceIntegrations WorkspaceIntegration[]

  @@map("integration_definitions")
}

/// Automation OS integration catalog. This mirrors integration_definitions but
/// uses the requested table name and status vocabulary for pack deployment.
model Integration {
  id          String   @id @default(uuid()) @db.Uuid
  key         String   @unique
  name        String
  category    String
  icon        String?
  description String
  authMethod  String   @default("oauth") @map("auth_method")
  status      String   @default("not_connected")
  demoNotes   String   @default("") @map("demo_notes")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  workspaceIntegrations WorkspaceIntegration[]

  @@map("integrations")
}

/// A workspace connection to an integration. Tenant+org scoped (RLS).
model WorkspaceIntegration {
  id             String    @id @default(uuid()) @db.Uuid
  tenantId       String    @map("tenant_id") @db.Uuid
  orgId          String    @map("org_id") @db.Uuid
  workspaceId    String?   @map("workspace_id") @db.Uuid
  definitionId   String    @map("definition_id") @db.Uuid
  integrationId  String?   @map("integration_id") @db.Uuid
  status         String    @default("not_connected")
  credentialRef  String?   @map("credential_ref")
  configSnapshot Json      @default("{}") @map("config_snapshot")
  lastSyncAt     DateTime? @map("last_sync_at")
  connectedBy    String?   @map("connected_by") @db.Uuid
  connectedAt    DateTime? @map("connected_at")
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")

  definition  IntegrationDefinition @relation(fields: [definitionId], references: [id])
  integration Integration?          @relation(fields: [integrationId], references: [id], onDelete: SetNull)
  workspace   Workspace?            @relation(fields: [workspaceId], references: [id], onDelete: SetNull)

  @@unique([orgId, definitionId])
  @@unique([workspaceId, integrationId])
  @@index([tenantId])
  @@index([orgId])
  @@index([workspaceId])
  @@index([integrationId])
  @@map("workspace_integrations")
}

/// A data input source for workflows. Tenant+org scoped (RLS).
model DataSource {
  id             String    @id @default(uuid()) @db.Uuid
  tenantId       String    @map("tenant_id") @db.Uuid
  orgId          String    @map("org_id") @db.Uuid
  workspaceId    String?   @map("workspace_id") @db.Uuid
  name           String
  type           String
  status         String    @default("active")
  config         Json      @default("{}")
  recordCount    Int       @default(0) @map("record_count")
  lastIngestedAt DateTime? @map("last_ingested_at")
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")

  workspace     Workspace?     @relation(fields: [workspaceId], references: [id], onDelete: SetNull)
  uploadedFiles UploadedFile[]

  @@index([tenantId])
  @@index([orgId])
  @@index([workspaceId])
  @@map("data_sources")
}

/// File uploaded to a data source. Tenant-scoped (RLS).
model UploadedFile {
  id           String   @id @default(uuid()) @db.Uuid
  tenantId     String   @map("tenant_id") @db.Uuid
  orgId        String   @map("org_id") @db.Uuid
  workspaceId  String?  @map("workspace_id") @db.Uuid
  dataSourceId String   @map("data_source_id") @db.Uuid
  filename     String
  mimeType     String   @map("mime_type")
  sizeBytes    Int      @map("size_bytes")
  storageKey   String   @map("storage_key")
  parsedCount  Int      @default(0) @map("parsed_count")
  status       String   @default("uploaded")
  createdAt    DateTime @default(now()) @map("created_at")

  dataSource DataSource @relation(fields: [dataSourceId], references: [id], onDelete: Cascade)
  workspace  Workspace? @relation(fields: [workspaceId], references: [id], onDelete: SetNull)

  @@index([tenantId])
  @@index([workspaceId])
  @@index([dataSourceId])
  @@map("uploaded_files")
}

/// Flexible industry-neutral object store. HR candidates, ecommerce orders,
/// real-estate properties, clinic appointments, logistics shipments, and other
/// vertical records all live here as typed JSON rather than hardcoded fields.
model BusinessObject {
  id          String   @id @default(uuid()) @db.Uuid
  tenantId    String   @map("tenant_id") @db.Uuid
  orgId       String   @map("org_id") @db.Uuid
  workspaceId String   @map("workspace_id") @db.Uuid
  industryKey String?  @map("industry_key")
  objectType  String   @map("object_type")
  externalId  String?  @map("external_id")
  displayName String   @map("display_name")
  status      String   @default("active")
  data        Json     @default("{}")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, objectType, externalId])
  @@index([tenantId])
  @@index([orgId])
  @@index([workspaceId])
  @@index([industryKey])
  @@index([objectType])
  @@map("business_objects")
}

/// Immutable activity event log. Tenant+org scoped (RLS).
model ActivityLog {
  id           String   @id @default(uuid()) @db.Uuid
  tenantId     String   @map("tenant_id") @db.Uuid
  orgId        String   @map("org_id") @db.Uuid
  workspaceId  String?  @map("workspace_id") @db.Uuid
  agentKey     String   @map("agent_key")
  agentName    String   @map("agent_name")
  action       String
  count        Int      @default(1)
  unit         String   @default("items")
  workflowKey  String   @map("workflow_key")
  workflowName String   @map("workflow_name")
  status       String   @default("completed")
  runId        String?  @map("run_id") @db.Uuid
  meta         Json     @default("{}")
  createdAt    DateTime @default(now()) @map("created_at")

  workspace Workspace? @relation(fields: [workspaceId], references: [id], onDelete: SetNull)

  @@index([tenantId])
  @@index([orgId])
  @@index([workspaceId])
  @@index([createdAt])
  @@index([agentKey])
  @@map("activity_logs")
}

/// Current ROI metric values by workspace and metric key.
model RoiMetric {
  id          String   @id @default(uuid()) @db.Uuid
  tenantId    String   @map("tenant_id") @db.Uuid
  orgId       String   @map("org_id") @db.Uuid
  workspaceId String   @map("workspace_id") @db.Uuid
  metricKey   String   @map("metric_key")
  label       String
  value       Float    @default(0)
  unit        String   @default("count")
  periodStart DateTime @map("period_start")
  periodEnd   DateTime @map("period_end")
  source      String   @default("demo")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, metricKey, periodStart])
  @@index([tenantId])
  @@index([orgId])
  @@index([workspaceId])
  @@index([metricKey])
  @@map("roi_metrics")
}

/// Per-workflow ROI impact snapshots.
model WorkflowRoiSnapshot {
  id                 String   @id @default(uuid()) @db.Uuid
  tenantId           String   @map("tenant_id") @db.Uuid
  orgId              String   @map("org_id") @db.Uuid
  workspaceId        String   @map("workspace_id") @db.Uuid
  deployedWorkflowId String?  @map("deployed_workflow_id") @db.Uuid
  workflowKey        String   @map("workflow_key")
  periodStart        DateTime @map("period_start")
  periodEnd          DateTime @map("period_end")
  hoursSaved         Float    @default(0) @map("hours_saved")
  tasksAutomated     Int      @default(0) @map("tasks_automated")
  salaryCostSaved    Float    @default(0) @map("salary_cost_saved")
  revenueOpportunity Float    @default(0) @map("revenue_opportunity")
  metrics            Json     @default("{}")
  source             String   @default("demo")
  createdAt          DateTime @default(now()) @map("created_at")

  workspace        Workspace         @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  deployedWorkflow DeployedWorkflow? @relation(fields: [deployedWorkflowId], references: [id], onDelete: SetNull)

  @@index([tenantId])
  @@index([orgId])
  @@index([workspaceId])
  @@index([deployedWorkflowId])
  @@index([workflowKey])
  @@index([periodStart])
  @@map("workflow_roi_snapshots")
}

/// Cumulative ROI snapshot per org per period. Tenant+org scoped (RLS).
model RoiSnapshot {
  id                     String   @id @default(uuid()) @db.Uuid
  tenantId               String   @map("tenant_id") @db.Uuid
  orgId                  String   @map("org_id") @db.Uuid
  workspaceId            String?  @map("workspace_id") @db.Uuid
  periodStart            DateTime @map("period_start")
  periodEnd              DateTime @map("period_end")
  hoursSaved             Int      @default(0) @map("hours_saved")
  tasksAutomated         Int      @default(0) @map("tasks_automated")
  salaryCostSaved        Int      @default(0) @map("salary_cost_saved")
  leadsRecovered         Int      @default(0) @map("leads_recovered")
  followUpsCompleted     Int      @default(0) @map("follow_ups_completed")
  reportsGenerated       Int      @default(0) @map("reports_generated")
  interviewsScheduled    Int      @default(0) @map("interviews_scheduled")
  supportTicketsResolved Int      @default(0) @map("support_tickets_resolved")
  revenueOpportunity     Int      @default(0) @map("revenue_opportunity")
  createdAt              DateTime @default(now()) @map("created_at")

  @@index([tenantId])
  @@index([orgId])
  @@index([workspaceId])
  @@index([periodStart])
  @@map("roi_snapshots")
}

/// Internal domain event outbox for workflow automation. Queue-ready. Tenant-scoped (RLS).
model AutomationEvent {
  id          String    @id @default(uuid()) @db.Uuid
  tenantId    String    @map("tenant_id") @db.Uuid
  orgId       String    @map("org_id") @db.Uuid
  workspaceId String?   @map("workspace_id") @db.Uuid
  type        String
  payload     Json      @default("{}")
  processedAt DateTime? @map("processed_at")
  attempts    Int       @default(0)
  createdAt   DateTime  @default(now()) @map("created_at")

  workspace Workspace? @relation(fields: [workspaceId], references: [id], onDelete: SetNull)

  @@index([tenantId])
  @@index([workspaceId])
  @@index([processedAt])
  @@index([type])
  @@map("automation_events")
}

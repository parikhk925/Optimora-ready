{
  "name": "@optimora/agency",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "scripts": {
    "lint": "eslint src",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run --exclude \"**/*.int.test.ts\"",
    "test:integration": "vitest run int.test",
    "build": "tsc -p tsconfig.json",
    "clean": "node -e \"const fs=require('fs');['dist','.turbo'].forEach(d=>fs.rmSync(d,{recursive:true,force:true}))\""
  },
  "devDependencies": {
    "@optimora/config": "workspace:*",
    "dotenv": "^17.4.2",
    "vitest": "^2.1.8"
  },
  "dependencies": {
    "@optimora/auth-core": "workspace:^",
    "@optimora/db": "workspace:^"
  }
}
